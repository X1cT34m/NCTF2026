from Crypto.Util.number import long_to_bytes
# bound = sqrt((N ^ 6 - 162 * N ^ 3 + 1) / (2 * N * sqrt(N) + 1100 * N ^ 3))
nbits = 512
N = 
e = 
c = 

# https://eprint.iacr.org/2025/1396 Theorem 9
denominator_approx = N^6 - 162 * N^3 + 1
cf = continued_fraction(e / denominator_approx)
convergents = cf.convergents()

for conv in convergents:
    b = conv.numerator()
    a = conv.denominator()

    if a == 0 or b == 0:
        continue

    try:
        # https://eprint.iacr.org/2025/1396 Theorem 8
        tmp1 = (N**3 - 1)**2 - (a * e / b)
        tmp2 = (N**3 + 1)**2 - (a * e / b)

        hat_p = round((0.5 * (sqrt(tmp1) + sqrt(tmp2)))^(1 / 3))
        if hat_p.bit_length() > nbits or hat_p.bit_length() < nbits:
            continue

        if hat_p > 1 and N % hat_p == 0:
            print("[!] Attack Success!")
            print(f"Found p: {hat_p}")
            actual_p = hat_p
            break

        R.<x> = PolynomialRing(Zmod(N))
        f = hat_p - x
        f = f.monic()
        roots = f.small_roots(x=2**(int(nbits * 0.6)), beta=0.5, epsilon=0.1)

        for r in roots:
            actual_p = int(hat_p + r)
            if actual_p > 1 and N % actual_p == 0:
                print("[!] Attack Success!")
                print(f"Found p: {actual_p}")
                break
        else:
            continue
        break

    except Exception:
        continue

else:
    print("[-] Attack Failed!")
    exit()
p = actual_p
q = N // p
phi6 = (p ** 6 - 1) * (q ** 6 - 1)
d = pow(e, -1, phi6)
m = pow(c, d, N)
flag = long_to_bytes(m)
print(flag)

# nctf{98b1e5c-9a3c-4d8e-9f1a-2b3c4d5e6f7g}
